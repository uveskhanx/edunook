{
  "rules": {
    ".read": "false",
    ".write": "false",

    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('profiles').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "profiles": {
      ".read": "true",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('profiles').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "!newData.hasChild('realEmail') && !newData.hasChild('phone') && !newData.hasChild('dob') && !newData.hasChild('email') && !newData.hasChild('preferences') && !newData.hasChild('history')"
      }
    },

    "usernames": {
      ".read": "true",
      "$username": {
        ".write": "auth != null && ((!data.exists() && newData.val() === auth.uid) || (data.val() === auth.uid && !newData.exists()) || root.child('profiles').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "courses": {
      ".read": "true",
      ".indexOn": ["slug"],
      "$courseId": {
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['id', 'userId', 'title', 'slug'])"
      }
    },

    "course_slugs": {
      ".read": "true",
      "$slug": {
        ".write": "auth != null"
      }
    },

    "chapters": {
      "$courseId": {
        ".read": "true",
        ".write": "auth != null && (root.child('courses').child($courseId).child('userId').val() === auth.uid || root.child('profiles').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "videos": {
      ".read": "true",
      "$courseId": {
        ".write": "auth != null && (root.child('courses').child($courseId).child('userId').val() === auth.uid || root.child('profiles').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "course_reviews": {
      "$courseId": {
        ".read": "true",
        "$reviewId": {
          ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid || root.child('courses').child($courseId).child('userId').val() === auth.uid)"
        }
      }
    },

    "followers": {
      ".read": "true",
      "$uid": {
        ".read": "true",
        "$followerUid": {
          ".write": "auth != null && auth.uid === $followerUid"
        }
      }
    },

    "following": {
      ".read": "true",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$targetUid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },

    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    },

    "chats": {
      "$chatId": {
        ".read": "auth != null && (!data.exists() || data.child('users').child(auth.uid).exists())",
        ".write": "auth != null && (!data.exists() || data.child('users').child(auth.uid).exists())"
      }
    },

    "messages": {
      "$chatId": {
        ".read": "auth != null && root.child('chats').child($chatId).child('users').child(auth.uid).exists()",
        "$messageId": {
          ".write": "auth != null && root.child('chats').child($chatId).child('users').child(auth.uid).exists()"
        }
      }
    },

    "user_chats": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$chatId": {
          ".write": "auth != null && (auth.uid === $uid || $chatId.contains(auth.uid))"
        }
      }
    },

    "tests": {
      ".read": "true",
      ".indexOn": ["slug"],
      "$testId": {
        ".write": "auth != null && (!data.exists() || data.child('creatorId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['id', 'creatorId', 'title', 'slug'])"
      }
    },

    "test_slugs": {
      ".read": "true",
      "$slug": {
        ".write": "auth != null"
      }
    },

    "enrollments": {
      "$courseId": {
        ".read": "auth != null && (root.child('courses').child($courseId).child('userId').val() === auth.uid || root.child('profiles').child(auth.uid).child('role').val() === 'admin')",
        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || root.child('courses').child($courseId).child('userId').val() === auth.uid || root.child('profiles').child(auth.uid).child('role').val() === 'admin')",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },

    "payments": {
      ".indexOn": ["teacher_id", "user_id"],
      ".read": "auth != null && ((query.orderByChild === 'teacher_id' && query.equalTo === auth.uid) || (query.orderByChild === 'user_id' && query.equalTo === auth.uid) || root.child('profiles').child(auth.uid).child('role').val() === 'admin')",
      "$paymentId": {
        ".read": "auth != null && (data.child('user_id').val() === auth.uid || data.child('teacher_id').val() === auth.uid || root.child('profiles').child(auth.uid).child('role').val() === 'admin')",
        ".write": "false"
      }
    },

    "presence": {
      ".read": "true",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
